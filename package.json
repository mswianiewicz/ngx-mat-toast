{
  "name": "ngx-mat-toast-workspace",
  "version": "0.0.0",
  "private": true,
  "packageManager": "npm@11.13.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve demo",
    "build": "npm run build:lib && npm run build:demo",
    "build:lib": "ng build ngx-mat-toast",
    "build:demo": "ng build demo",
    "watch:lib": "ng build ngx-mat-toast --watch --configuration development",
    "test": "npm run test:lib && npm run test:demo",
    "test:lib": "ng test ngx-mat-toast --watch=false",
    "test:demo": "ng test demo --watch=false",
    "test:ci": "npm run test:lib && npm run test:demo",
    "format": "prettier --write \"**/*.{ts,html,scss,md,json,yml,yaml}\" --ignore-path .prettierignore",
    "format:check": "prettier --check \"**/*.{ts,html,scss,md,json,yml,yaml}\" --ignore-path .prettierignore",
    "release": "npm run build:lib && npm publish ./dist/ngx-mat-toast --access public"
  },
  "dependencies": {
    "@angular/cdk": "^22.0.5",
    "@angular/common": "^22.0.7",
    "@angular/compiler": "^22.0.7",
    "@angular/core": "^22.0.7",
    "@angular/forms": "^22.0.7",
    "@angular/material": "^22.0.5",
    "@angular/platform-browser": "^22.0.7",
    "@angular/router": "^22.0.7",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.7",
    "@angular/cli": "^22.0.7",
    "@angular/compiler-cli": "^22.0.7",
    "jsdom": "^29.1.1",
    "ng-packagr": "^22.0.1",
    "prettier": "^3.9.5",
    "typescript": "~7.0.2",
    "vitest": "^4.0.8"
  }
}
